---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Crear Cuenta">
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-header">
        <div class="auth-logo">
          <img src="/3.png" alt="Logo" />
        </div>
        <h1>Crear cuenta</h1>
        <p>Empieza a gestionar tus reservas hoy mismo</p>
      </div>

      <form id="signup-form" class="auth-form">
        <div class="form-group">
          <label for="nombre_salon">Nombre de tu negocio</label>
          <input
            type="text"
            id="nombre_salon"
            name="nombre_salon"
            required
            placeholder="Ej: Barbería Elite"
          />
        </div>

        <div class="form-group">
          <label for="email">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="correo@ejemplo.com"
          />
        </div>

        <div class="form-group">
          <label for="password">Contraseña</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            placeholder="Mínimo 6 caracteres"
          />
        </div>

        <div id="error-message" class="error-msg" style="display: none;"></div>

        <button
          type="submit"
          id="signup-btn"
          class="btn-custom btn-primary-custom full-width">Crear cuenta</button
        >
      </form>

      <div class="auth-footer">
        <p>¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
      </div>
    </div>
  </div>

  <style>
    .auth-container {
      min-height: 85vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.5rem;
    }

    .auth-card {
      width: 100%;
      max-width: 380px;
      background: var(--bg-secondary);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-xl);
      padding: 2.5rem;
    }

    .auth-header {
      text-align: center;
      margin-bottom: 2rem;
    }

    .auth-logo {
      width: 48px;
      height: 48px;
      background: var(--accent-primary);
      color: #0c0f0a;
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
      font-weight: 700;
      margin: 0 auto 1.25rem;
    }

    .auth-header h1 {
      font-size: 1.375rem;
      font-weight: 700;
      margin-bottom: 0.375rem;
      letter-spacing: -0.02em;
    }
    .auth-header p {
      color: var(--text-secondary);
      font-size: 0.875rem;
    }

    .auth-form {
      display: flex;
      flex-direction: column;
      gap: 1.125rem;
    }

    .auth-form .btn-custom {
      margin-top: 0.375rem;
      padding: 0.625rem;
      font-size: 0.875rem;
    }

    .auth-footer {
      text-align: center;
      margin-top: 1.5rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--glass-border);
    }
    .auth-footer p {
      font-size: 0.8125rem;
      color: var(--text-secondary);
    }
    .auth-footer a {
      color: var(--accent-primary);
      font-weight: 600;
      text-decoration: none;
    }
    .auth-footer a:hover {
      text-decoration: underline;
    }
  </style>

  <script>
    const signupForm = document.getElementById(
      "signup-form",
    ) as HTMLFormElement;
    const signupBtn = document.getElementById(
      "signup-btn",
    ) as HTMLButtonElement;
    const errorMessage = document.getElementById(
      "error-message",
    ) as HTMLDivElement;

    signupForm?.addEventListener("submit", async (e) => {
      e.preventDefault();
      signupBtn.disabled = true;
      signupBtn.innerText = "Creando...";
      errorMessage.style.display = "none";

      const formData = new FormData(signupForm);
      const email = formData.get("email") as string;
      const password = formData.get("password") as string;
      const nombreSalon = formData.get("nombre_salon") as string;

      try {
        const res = await fetch("/api/auth/signup", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, password, nombreSalon }),
        });

        const result = await res.json();

        if (!res.ok)
          throw new Error(result.error || "Error al crear la cuenta");

        alert("¡Cuenta creada con éxito! Ya puedes iniciar sesión.");
        window.location.href = "/login";
      } catch (error: any) {
        errorMessage.innerText = error.message;
        errorMessage.style.display = "block";
        signupBtn.disabled = false;
        signupBtn.innerText = "Crear cuenta";
      }
    });
  </script>
</BaseLayout>
