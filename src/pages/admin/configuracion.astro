---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

// Fetch session and salon
const { data: { session } } = await supabase.auth.getSession();
const userId = session?.user?.id;

const { data: salon } = await supabase
  .from('salones')
  .select('*')
  .eq('owner_id', userId)
  .single();

if (!salon) return Astro.redirect('/admin?error=no_salon');
---

<AdminLayout title="Configuración">
  <div class="settings-page" data-salon-id={salon.id}>
    
    <!-- Tabs -->
    <div class="settings-tabs">
      <button class="tab active" onclick="switchTab('general')">General</button>
      <button class="tab" onclick="switchTab('design')">Diseño</button>
      <button class="tab" onclick="switchTab('integrations')">Integraciones</button>
    </div>

    <!-- General Tab -->
    <div class="tab-panel" id="general">
      <div class="settings-grid">
        
        <!-- Image Upload -->
        <div class="custom-card setting-card">
          <div class="setting-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
            <div>
              <h3>Imagen del negocio</h3>
              <p>Sube el logo o una foto de tu local</p>
            </div>
          </div>
          <div class="upload-area">
            <div class="preview-thumb" id="image-preview">
              {salon.logo_url ? <img src={salon.logo_url} alt="Logo" /> : <span>Sin imagen</span>}
            </div>
            <div class="upload-info">
              <input type="file" id="logo-input" accept="image/*" class="hidden" />
              <button class="btn-custom btn-primary-custom btn-sm" onclick="document.getElementById('logo-input').click()">Subir imagen</button>
              <p class="upload-hint">PNG o JPG, máximo 2MB</p>
            </div>
          </div>
        </div>

        <!-- Basic Info -->
        <div class="custom-card setting-card">
          <div class="setting-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            <div>
              <h3>Información básica</h3>
              <p>Datos principales de contacto</p>
            </div>
          </div>
          <form class="setting-form ajax-form">
            <div class="form-group">
              <label>Nombre comercial</label>
              <input type="text" name="nombre" value={salon.nombre} required />
            </div>
            <div class="form-group">
              <label>Teléfono WhatsApp</label>
              <input type="tel" name="telefono" value={salon.telefono} />
            </div>
            <button type="submit" class="btn-custom btn-primary-custom btn-sm">Guardar</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Design Tab -->
    <div class="tab-panel hidden" id="design">
      <div class="settings-grid">
        
        <!-- Colors -->
        <div class="custom-card setting-card">
          <div class="setting-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="13.5" cy="6.5" r="2.5"></circle><circle cx="17.5" cy="10.5" r="2.5"></circle><circle cx="8.5" cy="7.5" r="2.5"></circle><circle cx="6.5" cy="12.5" r="2.5"></circle><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.555C21.965 6.012 17.461 2 12 2z"></path></svg>
            <div>
              <h3>Paleta de colores</h3>
              <p>Colores que verán tus clientes</p>
            </div>
          </div>
          <form class="setting-form ajax-form">
            <div class="color-row">
              <div class="color-field">
                <label>Primario</label>
                <input type="color" name="color_primario" value={salon.color_primario || '#c1d63e'} />
              </div>
              <div class="color-field">
                <label>Acento</label>
                <input type="color" name="color_acento" value={salon.color_acento || '#a3b835'} />
              </div>
            </div>
            <button type="submit" class="btn-custom btn-primary-custom btn-sm">Aplicar colores</button>
          </form>
        </div>

        <!-- Theme -->
        <div class="custom-card setting-card">
          <div class="setting-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
            <div>
              <h3>Tema del dashboard</h3>
              <p>Cambia el aspecto de tu panel</p>
            </div>
          </div>
          <div class="theme-options">
            <label class="theme-opt active">
              <div class="theme-swatch dark"></div>
              <span>Dark</span>
            </label>
            <label class="theme-opt">
              <div class="theme-swatch midnight"></div>
              <span>Midnight</span>
            </label>
            <label class="theme-opt">
              <div class="theme-swatch forest"></div>
              <span>Forest</span>
            </label>
          </div>
        </div>
      </div>
    </div>

    <!-- Integrations Tab -->
    <div class="tab-panel hidden" id="integrations">
      <div class="settings-grid">
        
        <!-- Google Calendar -->
        <div class="custom-card setting-card integration">
          <div class="integration-top">
            <img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Google_Calendar_icon_%282020%29.svg" alt="Google Calendar" class="integration-icon" />
            <span class="badge badge-danger">Desconectado</span>
          </div>
          <h3>Google Calendar</h3>
          <p>Sincroniza tus citas automáticamente con tu calendario de Google.</p>
          <button class="btn-custom btn-outline full-width">Conectar con Google</button>
        </div>

        <!-- WhatsApp -->
        <div class="custom-card setting-card integration">
          <div class="integration-top">
            <img src="https://upload.wikimedia.org/wikipedia/commons/6/6b/WhatsApp.svg" alt="WhatsApp" class="integration-icon" />
            <span class="badge badge-success">Activo</span>
          </div>
          <h3>WhatsApp API</h3>
          <p>Envía recordatorios automáticos y confirmaciones de citas.</p>
          <div class="form-group" style="margin-top: 0.75rem;">
            <label>Mensaje de bienvenida</label>
            <textarea rows="2">¡Hola! Gracias por elegir {salon.nombre}. Tu cita ha sido confirmada...</textarea>
          </div>
          <button class="btn-custom btn-primary-custom full-width" style="background: #25D366; border-color: #25D366;">Configurar plantillas</button>
        </div>
      </div>
    </div>

  </div>

  <style>
    .settings-page {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    /* Tabs */
    .settings-tabs {
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--glass-border);
    }
    .tab {
      background: none;
      border: none;
      color: var(--text-muted);
      font-weight: 500;
      font-size: 0.8125rem;
      cursor: pointer;
      padding: 0.625rem 1rem;
      position: relative;
      transition: color var(--transition-fast);
    }
    .tab:hover { color: var(--text-secondary); }
    .tab.active {
      color: var(--text-primary);
    }
    .tab.active::after {
      content: '';
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 100%;
      height: 2px;
      background: var(--accent-primary);
    }

    /* Settings grid */
    .settings-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
      gap: 0.75rem;
    }
    .setting-card {
      padding: 1.5rem;
    }
    .setting-header {
      display: flex;
      align-items: flex-start;
      gap: 0.875rem;
      margin-bottom: 1.5rem;
    }
    .setting-header svg {
      color: var(--text-muted);
      margin-top: 2px;
      flex-shrink: 0;
    }
    .setting-header h3 {
      font-size: 0.9375rem;
      font-weight: 600;
      margin-bottom: 0.125rem;
    }
    .setting-header p {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    /* Upload */
    .upload-area {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }
    .preview-thumb {
      width: 80px;
      height: 80px;
      background: var(--bg-tertiary);
      border: 1px dashed var(--glass-border);
      border-radius: var(--radius-md);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
    }
    .preview-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .preview-thumb span {
      font-size: 0.6875rem;
      color: var(--text-muted);
    }
    .upload-hint {
      font-size: 0.6875rem;
      color: var(--text-muted);
      margin-top: 0.375rem;
    }

    /* Setting form */
    .setting-form {
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }
    .setting-form .btn-custom {
      align-self: flex-start;
    }

    /* Colors */
    .color-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .color-field {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }
    .color-field label {
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--text-secondary);
    }
    .color-field input[type="color"] {
      width: 100%;
      height: 44px;
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      cursor: pointer;
      background: var(--bg-tertiary);
      padding: 3px;
    }

    /* Theme */
    .theme-options {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .theme-opt {
      display: flex;
      align-items: center;
      gap: 0.875rem;
      padding: 0.75rem;
      background: var(--bg-tertiary);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      cursor: pointer;
      transition: border-color var(--transition-fast);
    }
    .theme-opt.active {
      border-color: var(--accent-primary);
    }
    .theme-opt span {
      font-size: 0.8125rem;
      font-weight: 500;
    }
    .theme-swatch {
      width: 32px;
      height: 32px;
      border-radius: var(--radius-sm);
      flex-shrink: 0;
    }
    .theme-swatch.dark { background: #0c0f0a; border: 1px solid rgba(255,255,255,0.1); }
    .theme-swatch.midnight { background: #0f172a; }
    .theme-swatch.forest { background: #14291a; }

    /* Integrations */
    .integration {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .integration-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 0.25rem;
    }
    .integration-icon {
      height: 28px;
      width: 28px;
    }
    .integration h3 {
      font-size: 0.9375rem;
      font-weight: 600;
    }
    .integration p {
      font-size: 0.8125rem;
      color: var(--text-secondary);
      line-height: 1.4;
      margin-bottom: 0.5rem;
    }

    .tab-panel.hidden { display: none; }

    @media (max-width: 768px) {
      .settings-grid { grid-template-columns: 1fr; }
      .upload-area { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <script>
    import { supabase } from '../../lib/supabase';

    const salonId = (document.querySelector('.settings-page') as HTMLElement).dataset.salonId;

    // Tab Switching
    (window as any).switchTab = (tabId: string) => {
      document.querySelectorAll('.tab-panel').forEach(t => t.classList.add('hidden'));
      document.getElementById(tabId)?.classList.remove('hidden');
      document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
      (event?.target as HTMLElement).classList.add('active');
    };

    // AJAX Form Handling
    document.querySelectorAll('.ajax-form').forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = btn.innerText;
        btn.disabled = true;
        btn.innerText = 'Guardando...';

        const formData = new FormData(form as HTMLFormElement);
        const data = Object.fromEntries(formData);

        // Eliminar columnas que no existen en la DB para evitar errores
        delete data.color_fondo;

        const { error } = await supabase.from('salones').update(data).eq('id', salonId);

        if (error) (window as any).showToast(error.message, 'error');
        else (window as any).showToast('Configuración actualizada', 'success');

        btn.disabled = false;
        btn.innerText = originalText;
      });
    });

    // Logo Upload Logic
    const logoInput = document.getElementById('logo-input') as HTMLInputElement;
    logoInput?.addEventListener('change', async (e) => {
      const file = logoInput.files?.[0];
      if (!file) return;

      (window as any).showToast('Subiendo imagen...', 'success');
      
      const fileExt = file.name.split('.').pop();
      const fileName = `${salonId}-${Math.random()}.${fileExt}`;
      const filePath = `logos/${fileName}`;

      const { error: uploadError } = await supabase.storage
        .from('salones_media')
        .upload(filePath, file);

      if (uploadError) {
        (window as any).showToast(uploadError.message, 'error');
        return;
      }

      const { data: { publicUrl } } = supabase.storage.from('salones_media').getPublicUrl(filePath);
      
      await supabase.from('salones').update({ logo_url: publicUrl }).eq('id', salonId);
      
      const preview = document.getElementById('image-preview');
      if (preview) preview.innerHTML = `<img src="${publicUrl}" alt="Logo" />`;
      
      (window as any).showToast('Imagen actualizada', 'success');
    });
  </script>
</AdminLayout>
