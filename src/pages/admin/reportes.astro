---
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Reportes">
  <div class="reports-page">
    
    <div class="reports-header">
      <div>
        <p class="page-desc">Inteligencia de negocio</p>
        <h2 class="page-title">Análisis de rendimiento</h2>
      </div>
      <div class="reports-actions">
        <select class="report-select">
          <option>Últimos 6 meses</option>
          <option>Este año</option>
        </select>
        <button class="btn-custom btn-outline">Exportar</button>
      </div>
    </div>

    <div class="charts-grid">
      
      <!-- Revenue Chart -->
      <div class="custom-card chart-card span-2">
        <h3>Ingresos mensuales</h3>
        <div class="bar-chart">
          {['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun'].map((m, i) => (
            <div class="bar-col">
              <div class="bar-track">
                <div class="bar-fill" style={`height: ${40 + Math.random() * 50}%`}></div>
              </div>
              <span class="bar-label">{m}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Team Performance -->
      <div class="custom-card chart-card">
        <h3>Rendimiento del equipo</h3>
        <div class="perf-list">
          {[
            { name: 'Carlos Ortiz', count: 124, percent: 85 },
            { name: 'Ana Pérez', count: 98, percent: 65 },
            { name: 'Luis Rivas', count: 76, percent: 45 }
          ].map(p => (
            <div class="perf-item">
              <div class="perf-header">
                <span class="perf-name">{p.name}</span>
                <span class="perf-count">{p.count} citas</span>
              </div>
              <div class="perf-bar-track">
                <div class="perf-bar-fill" style={`width: ${p.percent}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Top Services -->
      <div class="custom-card chart-card span-full">
        <h3>Servicios más solicitados</h3>
        <div class="top-services">
          {[
            { rank: '1', name: 'Corte Degradado', stat: '45% de reservas' },
            { rank: '2', name: 'Barba Premium', stat: '30% de reservas' },
            { rank: '3', name: 'Coloración', stat: '15% de reservas' }
          ].map(s => (
            <div class="top-service-card">
              <span class="rank">#{s.rank}</span>
              <strong>{s.name}</strong>
              <span class="rank-stat">{s.stat}</span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>

  <style>
    .reports-page {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .reports-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }
    .page-desc {
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.25rem;
    }
    .page-title {
      font-size: 1.375rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .reports-actions {
      display: flex;
      gap: 0.5rem;
    }
    .report-select {
      background: var(--bg-secondary);
      border: 1px solid var(--glass-border);
      color: var(--text-primary);
      padding: 0.4375rem 0.75rem;
      border-radius: var(--radius-md);
      font-size: 0.8125rem;
      font-weight: 500;
      font-family: inherit;
    }

    .charts-grid {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 0.75rem;
    }
    .chart-card {
      padding: 1.5rem;
    }
    .chart-card h3 {
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }
    .span-2 { grid-column: 1; }
    .span-full { grid-column: 1 / -1; }

    /* Bar chart */
    .bar-chart {
      display: flex;
      align-items: flex-end;
      gap: 0.75rem;
      height: 180px;
    }
    .bar-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      height: 100%;
    }
    .bar-track {
      flex: 1;
      width: 100%;
      background: var(--bg-tertiary);
      border-radius: var(--radius-sm);
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: flex-end;
    }
    .bar-fill {
      width: 100%;
      background: rgba(193, 214, 62, 0.2);
      border-radius: var(--radius-sm);
      transition: height 800ms ease, background 200ms ease;
    }
    .bar-col:hover .bar-fill {
      background: var(--accent-primary);
    }
    .bar-label {
      font-size: 0.625rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* Performance */
    .perf-list {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .perf-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.375rem;
    }
    .perf-name {
      font-size: 0.8125rem;
      font-weight: 600;
    }
    .perf-count {
      font-size: 0.6875rem;
      color: var(--text-muted);
    }
    .perf-bar-track {
      height: 6px;
      background: var(--bg-tertiary);
      border-radius: 3px;
      overflow: hidden;
    }
    .perf-bar-fill {
      height: 100%;
      background: var(--accent-primary);
      border-radius: 3px;
      transition: width 800ms ease;
    }

    /* Top services */
    .top-services {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }
    .top-service-card {
      background: var(--bg-tertiary);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 1.25rem;
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
      transition: border-color var(--transition-fast);
    }
    .top-service-card:hover {
      border-color: var(--border-active);
    }
    .rank {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent-primary);
    }
    .top-service-card strong {
      font-size: 0.9375rem;
    }
    .rank-stat {
      font-size: 0.6875rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    @media (max-width: 768px) {
      .reports-header { flex-direction: column; align-items: stretch; gap: 0.75rem; }
      .charts-grid { grid-template-columns: 1fr; }
      .span-2 { grid-column: 1; }
      .top-services { grid-template-columns: 1fr; }
    }
  </style>
</AdminLayout>
