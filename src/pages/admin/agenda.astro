---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { supabase } from '../../lib/supabase';

const { data: { session } } = await supabase.auth.getSession();
const userId = session?.user?.id;

const { data: salon } = await supabase
  .from('salones')
  .select('id')
  .eq('owner_id', userId)
  .single();

const { data: citas } = await supabase
  .from('citas')
  .select('*, profesionales(nombre), servicios(nombre)')
  .eq('salon_id', salon?.id)
  .order('fecha_inicio', { ascending: true });
---

<AdminLayout title="Agenda">
  <div class="agenda-page">
    <div class="agenda-toolbar">
      <div class="date-nav">
        <button class="btn-custom btn-icon btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
        </button>
        <span class="date-label">Hoy, 12 de Mayo</span>
        <button class="btn-custom btn-icon btn-outline">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
        </button>
      </div>
      <div class="view-toggle">
        <button class="toggle-btn active">Lista</button>
        <button class="toggle-btn">Calendario</button>
      </div>
    </div>

    <div class="agenda-list">
      {citas && citas.length > 0 ? citas.map(cita => (
        <div class="custom-card agenda-item">
          <div class="agenda-indicator"></div>
          <div class="agenda-time">
            {new Date(cita.fecha_inicio).toLocaleTimeString('es', { hour: '2-digit', minute: '2-digit' })}
          </div>
          <div class="agenda-info">
            <strong>{cita.cliente_nombre}</strong>
            <span>{cita.servicios?.nombre} · <em>{cita.profesionales?.nombre}</em></span>
          </div>
          <span class="badge badge-success">Confirmada</span>
        </div>
      )) : (
        <div class="empty-state-box">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="empty-icon"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
          <p>No hay citas registradas para este día.</p>
        </div>
      )}
    </div>
  </div>

  <style>
    .agenda-page {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .agenda-toolbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .date-nav {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .date-label {
      font-weight: 600;
      font-size: 0.875rem;
      min-width: 140px;
      text-align: center;
    }

    .view-toggle {
      display: flex;
      background: var(--bg-secondary);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 3px;
    }
    .toggle-btn {
      border: none;
      background: transparent;
      color: var(--text-muted);
      padding: 0.375rem 0.875rem;
      border-radius: var(--radius-sm);
      font-weight: 500;
      font-size: 0.8125rem;
      cursor: pointer;
      transition: all var(--transition-fast);
    }
    .toggle-btn.active {
      background: var(--bg-tertiary);
      color: var(--text-primary);
    }

    .agenda-list {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .agenda-item {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1rem 1.25rem;
      position: relative;
    }
    .agenda-indicator {
      width: 3px;
      height: 32px;
      background: var(--accent-primary);
      border-radius: 2px;
      flex-shrink: 0;
    }
    .agenda-time {
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--text-primary);
      min-width: 48px;
    }
    .agenda-info {
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .agenda-info strong {
      font-size: 0.875rem;
      font-weight: 600;
    }
    .agenda-info span {
      color: var(--text-secondary);
      font-size: 0.75rem;
    }
    .agenda-info em {
      font-style: normal;
      color: var(--accent-primary);
    }

    .empty-state-box {
      text-align: center;
      padding: 3rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }
    .empty-icon { color: var(--text-muted); }
    .empty-state-box p {
      color: var(--text-muted);
      font-size: 0.8125rem;
    }

    @media (max-width: 640px) {
      .agenda-toolbar { flex-direction: column; gap: 0.75rem; }
    }
  </style>
</AdminLayout>
