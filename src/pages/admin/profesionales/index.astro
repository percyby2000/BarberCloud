---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { data: { session } } = await supabase.auth.getSession();
const userId = session?.user?.id;

const { data: salon } = await supabase
  .from('salones')
  .select('id')
  .eq('owner_id', userId)
  .single();

const { data: profesionales } = await supabase
  .from('profesionales')
  .select('*')
  .eq('salon_id', salon?.id)
  .order('nombre', { ascending: true });
---

<AdminLayout title="Equipo">
  <div class="page-top">
    <p class="page-desc">Gestiona los profesionales de tu negocio.</p>
    <button class="btn-custom btn-primary-custom" onclick="openModal()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
      Nuevo profesional
    </button>
  </div>

  <div class="team-grid">
    {profesionales?.map(p => (
      <div class="custom-card team-card">
        <div class="team-header">
          <div class="team-avatar">{p.nombre[0]}</div>
          <div class="team-actions">
            <button class="btn-custom btn-ghost btn-sm" onclick={`editProf(${JSON.stringify(p)})`}>Editar</button>
            <button class="btn-custom btn-destructive btn-sm" onclick={`deleteProf(${p.id})`}>Eliminar</button>
          </div>
        </div>
        <div class="team-info">
          <strong>{p.nombre} {p.apellido}</strong>
          <span class="team-specialty">{p.especialidades?.join(' · ')}</span>
        </div>
        <div class="team-contact">
          {p.email && <span>{p.email}</span>}
          {p.telefono && <span>{p.telefono}</span>}
        </div>
      </div>
    ))}
  </div>

  <!-- Modal -->
  <div id="prof-modal" class="modal-overlay">
    <div class="modal-content custom-card">
      <h2 id="modal-title" class="modal-heading">Nuevo profesional</h2>
      <form id="prof-form">
        <input type="hidden" name="id" id="prof-id" />
        <div class="form-row">
          <div class="form-group">
            <label>Nombre</label>
            <input type="text" name="nombre" required />
          </div>
          <div class="form-group">
            <label>Apellido</label>
            <input type="text" name="apellido" required />
          </div>
        </div>
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required />
        </div>
        <div class="form-group">
          <label>Teléfono</label>
          <input type="tel" name="telefono" />
        </div>
        <div class="form-group">
          <label>Especialidades (separadas por coma)</label>
          <input type="text" name="especialidades_raw" placeholder="Corte, Color, Barba" />
        </div>
        <div class="modal-buttons">
          <button type="button" class="btn-custom btn-outline" onclick="closeModal()">Cancelar</button>
          <button type="submit" class="btn-custom btn-primary-custom">Guardar</button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .page-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
    }
    .page-desc {
      color: var(--text-secondary);
      font-size: 0.8125rem;
    }

    .team-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 0.75rem;
    }
    .team-card {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.875rem;
    }
    .team-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }
    .team-avatar {
      width: 44px;
      height: 44px;
      background: var(--bg-tertiary);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-full);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 1rem;
      color: var(--accent-primary);
    }
    .team-actions {
      display: flex;
      gap: 0.25rem;
    }
    .team-info strong {
      font-size: 0.9375rem;
      display: block;
      margin-bottom: 0.125rem;
    }
    .team-specialty {
      font-size: 0.75rem;
      color: var(--accent-primary);
      font-weight: 500;
    }
    .team-contact {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
    }
    .team-contact span {
      font-size: 0.75rem;
      color: var(--text-muted);
    }

    .modal-heading {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1.25rem;
    }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .form-group {
      margin-bottom: 0.875rem;
    }

    @media (max-width: 640px) {
      .page-top { flex-direction: column; gap: 0.75rem; align-items: stretch; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    import { supabase } from '../../../lib/supabase';
    const modal = document.getElementById('prof-modal');
    const form = document.getElementById('prof-form') as HTMLFormElement;
    
    (window as any).openModal = () => {
      form.reset();
      (document.getElementById('prof-id') as HTMLInputElement).value = '';
      (document.getElementById('modal-title') as HTMLElement).innerText = 'Nuevo profesional';
      modal!.style.display = 'flex';
    };

    (window as any).closeModal = () => {
      modal!.style.display = 'none';
    };

    (window as any).editProf = (p: any) => {
      (document.getElementById('modal-title') as HTMLElement).innerText = 'Editar profesional';
      (document.getElementById('prof-id') as HTMLInputElement).value = p.id;
      (form.elements.namedItem('nombre') as HTMLInputElement).value = p.nombre;
      (form.elements.namedItem('apellido') as HTMLInputElement).value = p.apellido;
      (form.elements.namedItem('email') as HTMLInputElement).value = p.email;
      (form.elements.namedItem('telefono') as HTMLInputElement).value = p.telefono;
      (form.elements.namedItem('especialidades_raw') as HTMLInputElement).value = p.especialidades?.join(', ') || '';
      modal!.style.display = 'flex';
    };

    (window as any).deleteProf = async (id: number) => {
      if (!confirm('¿Seguro que quieres eliminar a este profesional?')) return;
      const { error } = await supabase.from('profesionales').delete().eq('id', id);
      if (error) (window as any).showToast(error.message, 'error');
      else {
        (window as any).showToast('Profesional eliminado', 'success');
        setTimeout(() => window.location.reload(), 1000);
      }
    };

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const id = formData.get('id');
      const tags = (formData.get('especialidades_raw') as string).split(',').map(t => t.trim()).filter(t => t !== '');
      
      const data = {
        nombre: formData.get('nombre'),
        apellido: formData.get('apellido'),
        email: formData.get('email'),
        telefono: formData.get('telefono'),
        especialidades: tags,
      };

      const { data: { session } } = await supabase.auth.getSession();
      const { data: salon } = await supabase.from('salones').select('id').eq('owner_id', session?.user.id).single();
      
      let res;
      if (id) res = await supabase.from('profesionales').update(data).eq('id', id);
      else res = await supabase.from('profesionales').insert([{ ...data, salon_id: salon.id }]);

      if (res.error) (window as any).showToast(res.error.message, 'error');
      else {
        (window as any).showToast('Equipo actualizado', 'success');
        (window as any).closeModal();
        setTimeout(() => window.location.reload(), 1000);
      }
    });
  </script>
</AdminLayout>
