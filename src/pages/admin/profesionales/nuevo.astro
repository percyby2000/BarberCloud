---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { supabase } from '../../../lib/supabase';

const { data: salon } = await supabase
  .from('salones')
  .select('id')
  .limit(1)
  .single();

const salonId = salon?.id;
---

<AdminLayout title="Nuevo Profesional">
  <div class="new-prof-page" data-salon-id={salonId}>
    <a href="/admin/profesionales" class="back-link">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
      Volver al equipo
    </a>

    <div class="custom-card form-container">
      <form id="nuevo-prof-form">
        <div class="form-section">
          <h3>Información básica</h3>
          <div class="form-row">
            <div class="form-group">
              <label for="nombre">Nombre</label>
              <input type="text" id="nombre" name="nombre" required placeholder="Ej: Nicolás" />
            </div>
            <div class="form-group">
              <label for="apellido">Apellido</label>
              <input type="text" id="apellido" name="apellido" required placeholder="Ej: García" />
            </div>
          </div>
          <div class="form-group">
            <label for="bio">Biografía / Perfil</label>
            <textarea id="bio" name="bio" rows="2" placeholder="Contanos sobre este profesional..."></textarea>
          </div>
        </div>

        <div class="form-section">
          <h3>Contacto y especialidades</h3>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="email@ejemplo.com" />
            </div>
            <div class="form-group">
              <label for="telefono">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" placeholder="+54 9 11 ..." />
            </div>
          </div>
          <div class="form-group">
            <label for="especialidades">Especialidades (separadas por coma)</label>
            <input type="text" id="especialidades" name="especialidades" placeholder="Cortes, Barba, Coloración" />
          </div>
        </div>

        <div id="message" class="message hidden"></div>

        <div class="form-actions">
          <button type="reset" class="btn-custom btn-outline">Limpiar</button>
          <button type="submit" id="save-btn" class="btn-custom btn-primary-custom">Guardar profesional</button>
        </div>
      </form>
    </div>
  </div>

  <style>
    .new-prof-page {
      max-width: 700px;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      color: var(--text-muted);
      font-weight: 500;
      font-size: 0.8125rem;
      text-decoration: none;
      margin-bottom: 1.25rem;
      transition: color var(--transition-fast);
    }
    .back-link:hover { color: var(--text-primary); }

    .form-container {
      padding: 2rem;
    }

    .form-section {
      margin-bottom: 2rem;
    }
    .form-section h3 {
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--glass-border);
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    .form-group {
      margin-bottom: 0.875rem;
    }

    .message {
      padding: 0.75rem;
      border-radius: var(--radius-md);
      font-weight: 500;
      font-size: 0.8125rem;
      text-align: center;
      margin-bottom: 1rem;
    }
    .message.success {
      background: rgba(62, 207, 113, 0.1);
      color: var(--accent-success);
      border: 1px solid rgba(62, 207, 113, 0.15);
    }
    .message.error {
      background: rgba(229, 83, 75, 0.1);
      color: var(--accent-danger);
      border: 1px solid rgba(229, 83, 75, 0.15);
    }

    .form-actions {
      display: flex;
      justify-content: flex-end;
      gap: 0.5rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--glass-border);
    }

    @media (max-width: 640px) {
      .form-row { grid-template-columns: 1fr; }
    }
  </style>

  <script is:inline>
    const form = document.getElementById('nuevo-prof-form');
    const saveBtn = document.getElementById('save-btn');
    const message = document.getElementById('message');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      saveBtn.disabled = true;
      saveBtn.innerText = 'Guardando...';
      message.classList.add('hidden');

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      
      data.especialidades = data.especialidades.split(',').map(s => s.trim()).filter(s => s !== '');
      
      const salonId = document.querySelector('.new-prof-page').dataset.salonId;
      data.salon_id = salonId;

      try {
        const res = await fetch('/api/admin/profesionales', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        if (res.ok) {
          message.innerText = '¡Profesional creado con éxito!';
          message.className = 'message success';
          message.classList.remove('hidden');
          setTimeout(() => window.location.href = '/admin/profesionales', 1500);
        } else {
          throw new Error('Error al guardar');
        }
      } catch (e) {
        message.innerText = 'Error al guardar el profesional. Intenta nuevamente.';
        message.className = 'message error';
        message.classList.remove('hidden');
        saveBtn.disabled = false;
        saveBtn.innerText = 'Guardar profesional';
      }
    });
  </script>
</AdminLayout>
