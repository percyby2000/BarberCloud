---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';

const { salon: slug } = Astro.params;

const { data: salon } = await supabase
  .from('salones')
  .select('*')
  .eq('slug', slug)
  .single();

if (!salon) return Astro.redirect('/404');
---

<BaseLayout title={`Confirmar Reserva | ${salon.nombre}`}>
  <div class="booking-flow" data-salon-id={salon.id} style={`--accent-primary: ${salon.color_primario || '#c1d63e'};`}>
    <div class="booking-header">
      <div class="steps">
        <span class="step done">✓</span>
        <span class="step-line filled"></span>
        <span class="step done">✓</span>
        <span class="step-line filled"></span>
        <span class="step done">✓</span>
        <span class="step-line filled"></span>
        <span class="step active">4</span>
      </div>
      <h1>Confirma tu reserva</h1>
      <p class="booking-sub">Estás a un paso de completar tu cita</p>
    </div>

    <div class="confirm-grid">
      <!-- Summary -->
      <div class="custom-card summary-panel">
        <h3 class="panel-title">Resumen de la cita</h3>
        <div id="final-summary" class="summary-rows"></div>
      </div>

      <!-- Form -->
      <div class="custom-card form-panel">
        <h3 class="panel-title">Tus datos</h3>
        <form id="booking-form">
          <div class="form-group">
            <label>Nombre completo</label>
            <input type="text" name="nombre" required placeholder="Ej: Juan Pérez" />
          </div>
          <div class="form-group">
            <label>Teléfono (WhatsApp)</label>
            <input type="tel" name="telefono" required placeholder="+51 9..." />
          </div>
          <div class="form-group">
            <label>Notas adicionales (opcional)</label>
            <textarea name="notas" rows="2" placeholder="Algún detalle que debamos saber..."></textarea>
          </div>
          <button type="submit" id="confirm-btn" class="btn-custom btn-primary-custom full-width">Confirmar reserva</button>
        </form>
      </div>
    </div>
  </div>

  <style>
    .booking-flow { max-width: 800px; margin: 0 auto; padding: 3rem 1.5rem; }
    
    .booking-header { text-align: center; margin-bottom: 2.5rem; }
    .steps { display: flex; justify-content: center; align-items: center; gap: 0; margin-bottom: 1.5rem; }
    .step { 
      width: 32px; height: 32px; border-radius: var(--radius-full); 
      background: var(--bg-tertiary); border: 1px solid var(--glass-border);
      display: flex; align-items: center; justify-content: center; 
      font-weight: 600; font-size: 0.75rem; color: var(--text-muted); 
      flex-shrink: 0;
    }
    .step.active { background: var(--accent-primary); color: #0c0f0a; border-color: var(--accent-primary); }
    .step.done { background: var(--bg-tertiary); color: var(--accent-primary); border-color: var(--accent-primary); }
    .step-line { width: 32px; height: 1px; background: var(--glass-border); }
    .step-line.filled { background: var(--accent-primary); }
    
    .booking-header h1 { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 0.5rem; }
    .booking-sub { font-size: 0.8125rem; color: var(--text-secondary); }

    .confirm-grid {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 0.75rem;
    }

    .panel-title {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--accent-primary);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-bottom: 1.25rem;
    }

    .summary-panel { padding: 1.5rem; }
    .summary-rows {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .summary-item {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
    }
    .summary-item .s-label {
      font-size: 0.6875rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .summary-item .s-value {
      font-size: 0.9375rem;
      font-weight: 600;
    }
    .price-total {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--accent-primary);
      margin-top: 0.75rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--glass-border);
    }

    .form-panel {
      padding: 1.5rem;
    }
    .form-group {
      margin-bottom: 0.875rem;
    }
    .form-panel .btn-custom {
      margin-top: 0.5rem;
      padding: 0.625rem;
    }

    @media (max-width: 640px) {
      .confirm-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    import { supabase } from '../../../lib/supabase';
    const service = JSON.parse(sessionStorage.getItem('reserva_servicio') || '{}');
    const prof = JSON.parse(sessionStorage.getItem('reserva_profesional') || '{}');
    const fecha = JSON.parse(sessionStorage.getItem('reserva_fecha') || '{}');
    const salonId = (document.querySelector('.booking-flow') as HTMLElement).dataset.salonId;

    const summary = document.getElementById('final-summary');
    if (summary) {
      summary.innerHTML = `
        <div class="summary-item"><span class="s-label">Servicio</span><span class="s-value">${service.nombre}</span></div>
        <div class="summary-item"><span class="s-label">Profesional</span><span class="s-value">${prof.nombre}</span></div>
        <div class="summary-item"><span class="s-label">Fecha</span><span class="s-value">${fecha.fecha}</span></div>
        <div class="summary-item"><span class="s-label">Hora</span><span class="s-value">${fecha.hora}</span></div>
        <div class="summary-item"><span class="price-total">S/ ${service.precio}</span></div>
      `;
    }

    document.getElementById('booking-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = document.getElementById('confirm-btn') as HTMLButtonElement;
      btn.disabled = true;
      btn.innerText = 'Procesando...';

      const formData = new FormData(e.target as HTMLFormElement);
      
      const today = new Date();
      const isoDate = `${today.getFullYear()}-05-12T${fecha.hora}:00Z`;

      const data = {
        cliente_nombre: formData.get('nombre'),
        cliente_telefono: formData.get('telefono'),
        notas: formData.get('notas'),
        servicio_id: service.id,
        profesional_id: prof.id,
        salon_id: salonId,
        fecha_inicio: isoDate,
        fecha_fin: isoDate,
        estado: 'confirmada'
      };

      try {
        const { error } = await supabase.from('citas').insert([data]);
        if (error) throw error;
        sessionStorage.clear();
        const slug = window.location.pathname.split('/')[2];
        window.location.href = `/reservar/${slug}/exito`;
      } catch (err: any) {
        alert('Error: ' + err.message);
        btn.disabled = false;
        btn.innerText = 'Confirmar reserva';
      }
    });
  </script>
</BaseLayout>
