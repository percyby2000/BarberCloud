---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';

const { salon: slug } = Astro.params;

const { data: salon } = await supabase
  .from('salones')
  .select('id, nombre, color_primario')
  .eq('slug', slug)
  .single();

if (!salon) return Astro.redirect('/404');
---

<BaseLayout title={`¡Reserva Exitosa! - ${salon.nombre}`}>
  <div class="success-page">
    <div class="success-card">
      <div class="success-icon">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>

      <h1>¡Todo listo!</h1>
      <p class="success-desc">Tu reserva en <strong>{salon.nombre}</strong> ha sido confirmada con éxito.</p>

      <div class="summary-box" id="summary-content">
        <!-- JS Loaded -->
      </div>

      <div class="success-actions">
        <a href={`/${slug}`} class="btn-custom btn-primary-custom btn-lg full-width">Volver al inicio</a>
        <p class="success-note">Recibirás un recordatorio por WhatsApp</p>
      </div>
    </div>
  </div>

  <style>
    .success-page {
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.5rem;
    }

    .success-card {
      width: 100%;
      max-width: 440px;
      background: var(--bg-secondary);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-xl);
      padding: 3rem 2.5rem;
      text-align: center;
    }

    .success-icon {
      width: 64px;
      height: 64px;
      background: rgba(62, 207, 113, 0.1);
      border: 1px solid rgba(62, 207, 113, 0.15);
      border-radius: var(--radius-full);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.5rem;
      color: var(--accent-success);
    }

    .success-card h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin-bottom: 0.5rem;
    }
    .success-desc {
      color: var(--text-secondary);
      font-size: 0.9375rem;
      margin-bottom: 2rem;
      line-height: 1.5;
    }
    .success-desc strong {
      color: var(--text-primary);
    }

    .summary-box {
      background: var(--bg-tertiary);
      border: 1px solid var(--glass-border);
      border-radius: var(--radius-md);
      padding: 1.25rem;
      text-align: left;
      margin-bottom: 2rem;
    }

    .summary-row {
      display: flex;
      flex-direction: column;
      gap: 0.125rem;
      padding: 0.375rem 0;
    }
    .summary-row + .summary-row {
      border-top: 1px solid var(--glass-border);
    }
    .sr-label {
      font-size: 0.6875rem;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .sr-value {
      font-size: 0.875rem;
      font-weight: 600;
    }

    .success-actions {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .success-note {
      font-size: 0.6875rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
  </style>

  <script is:inline>
    const summary = document.getElementById('summary-content');
    const service = JSON.parse(sessionStorage.getItem('reserva_servicio') || '{}');
    const prof = JSON.parse(sessionStorage.getItem('reserva_profesional') || '{}');
    const fecha = JSON.parse(sessionStorage.getItem('reserva_fecha') || '{}');

    summary.innerHTML = `
      <div class="summary-row">
        <span class="sr-label">Servicio</span>
        <span class="sr-value">${service.nombre || 'Servicio'}</span>
      </div>
      <div class="summary-row">
        <span class="sr-label">Profesional</span>
        <span class="sr-value">${prof.nombre || 'Profesional'}</span>
      </div>
      <div class="summary-row">
        <span class="sr-label">Cuándo</span>
        <span class="sr-value">${fecha.fecha} a las ${fecha.hora} hs</span>
      </div>
    `;
  </script>
</BaseLayout>
