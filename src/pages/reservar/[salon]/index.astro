---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { supabase } from '../../../lib/supabase';

const { salon: slug } = Astro.params;

const { data: salon } = await supabase
  .from('salones')
  .select('*')
  .eq('slug', slug)
  .single();

if (!salon) return Astro.redirect('/404');

const { data: servicios } = await supabase
  .from('servicios')
  .select('*')
  .eq('salon_id', salon.id)
  .eq('activo', true);
---

<BaseLayout title={`Reservar en ${salon.nombre}`}>
  <div class="booking-flow">
    <div class="booking-header">
      <div class="steps">
        <span class="step active">1</span>
        <span class="step-line"></span>
        <span class="step">2</span>
        <span class="step-line"></span>
        <span class="step">3</span>
        <span class="step-line"></span>
        <span class="step">4</span>
      </div>
      <h1>Selecciona un servicio</h1>
    </div>

    <div class="options-list">
      {servicios?.map(s => (
        <button class="custom-card option-card" onclick={`selectService(${JSON.stringify(s)})`}>
          <div class="option-info">
            <h3>{s.nombre}</h3>
            <span>{s.duracion_min} min</span>
          </div>
          <strong class="option-price">S/ {s.precio}</strong>
        </button>
      ))}
    </div>
  </div>

  <style>
    .booking-flow { max-width: 640px; margin: 0 auto; padding: 3rem 1.5rem; }
    
    .booking-header { text-align: center; margin-bottom: 2.5rem; }
    .steps { display: flex; justify-content: center; align-items: center; gap: 0; margin-bottom: 1.5rem; }
    .step { 
      width: 32px; height: 32px; border-radius: var(--radius-full); 
      background: var(--bg-tertiary); border: 1px solid var(--glass-border);
      display: flex; align-items: center; justify-content: center; 
      font-weight: 600; font-size: 0.75rem; color: var(--text-muted); 
      flex-shrink: 0;
    }
    .step.active { background: var(--accent-primary); color: #0c0f0a; border-color: var(--accent-primary); }
    .step.done { background: var(--bg-tertiary); color: var(--accent-primary); border-color: var(--accent-primary); }
    .step-line { width: 32px; height: 1px; background: var(--glass-border); }
    
    .booking-header h1 { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; }

    .options-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .option-card { 
      width: 100%; display: flex; justify-content: space-between; align-items: center; 
      padding: 1.25rem; text-align: left; cursor: pointer; 
      transition: border-color var(--transition-fast);
    }
    .option-card:hover { border-color: var(--border-active); }
    .option-info h3 { font-size: 0.9375rem; font-weight: 600; margin-bottom: 0.125rem; }
    .option-info span { font-size: 0.75rem; color: var(--text-secondary); }
    .option-price { font-size: 1.125rem; font-weight: 700; color: var(--accent-primary); }
  </style>

  <script is:inline>
    function selectService(service) {
      sessionStorage.setItem('reserva_servicio', JSON.stringify(service));
      const slug = window.location.pathname.split('/')[2];
      window.location.href = `/reservar/${slug}/profesional`;
    }
  </script>
</BaseLayout>
